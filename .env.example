# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# Railway PostgreSQL — use DATABASE_PUBLIC_URL value from Railway Variables tab
DATABASE_URL=postgresql://postgres:PASSWORD@host.proxy.rlwy.net:PORT/railway

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your-long-random-secret-here

# Stripe — get these from stripe.com/dashboard
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here
STRIPE_PRICE_ID=price_your-price-id-here

# Your app's public URL (Railway provides this)
APP_URL=https://your-app.up.railway.app
